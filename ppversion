    function openCase() {
        const betInput = document.getElementById('case-bet').value;
        let bet = parseInt(betInput);
        if (isNaN(bet) || bet < 1 || bet > saldo) {
            alert("Puntata non valida!");
            return;
        }
        const caseKey = document.getElementById('case-type').value;
        const selectedCase = caseData[caseKey];
        if (!selectedCase) return;
        saldo -= bet;
        updateUI();
        document.getElementById('case-open-btn').classList.add('hidden');
        document.getElementById('case-again-btn').classList.add('hidden');
        document.getElementById('case-result').innerText = `Apertura ${selectedCase.name} in corso...`;
        document.getElementById('case-animation').style.display = 'block';
        document.getElementById('skin-reveal').innerText = "SCRATCHING...";
        setTimeout(() => {
            let rand = Math.random() * 100;
            let cumulative = 0;
            let wonSkin = null;
            for (let drop of selectedCase.drops) {
                cumulative += drop.chance;
                if (rand <= cumulative) {
                    wonSkin = drop;
                    break;
                }
            }
            if (!wonSkin) wonSkin = selectedCase.drops[selectedCase.drops.length - 1];
            const winAmount = Math.round(bet * wonSkin.multiplier);
            saldo += winAmount;
            updateUI();
            const color = wonSkin.color || '#ffffff';
            document.getElementById('skin-reveal').style.background = color;
            document.getElementById('skin-reveal').style.color = (wonSkin.rarity === "Covert") ? "#000" : "#fff";
            document.getElementById('skin-reveal').innerText = `${wonSkin.name} (${wonSkin.rarity}) → +$${winAmount.toLocaleString()}`;
            document.getElementById('case-result').innerHTML =
                `Hai aperto una <b>${selectedCase.name}</b><br>` +
                `Risultato: <span style="color:${color}">${wonSkin.name}</span> (${wonSkin.rarity})<br>` +
                (winAmount > bet ? `Vinto: +$${winAmount.toLocaleString()} (${wonSkin.multiplier}x)` : "Perso (skin di basso valore)");
            document.getElementById('case-again-btn').classList.remove('hidden');
        }, 2200);
    }
